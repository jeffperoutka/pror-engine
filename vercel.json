{
  "version": 2,
  "functions": {
    "api/**/*.js": {
      "maxDuration": 300
    }
  },
  "routes": [
    { "src": "/api/slack/events", "dest": "/api/slack/events.js" },
    { "src": "/api/slack/commands", "dest": "/api/slack/commands.js" },
    { "src": "/api/slack/interact", "dest": "/api/slack/interact.js" },
    { "src": "/api/health", "dest": "/api/health.js" },
    { "src": "/api/cron/digest", "dest": "/api/cron/digest.js" },
    { "src": "/api/webhooks/engain", "dest": "/api/webhooks/engain.js" },
    { "src": "/api/cron/gmail-poll", "dest": "/api/cron/gmail-poll.js" },
    { "src": "/api/cron/sender-health", "dest": "/api/cron/sender-health.js" },
    { "src": "/api/cron/prospect-replenish", "dest": "/api/cron/prospect-replenish.js" },
    { "src": "/api/cron/weekly-digest", "dest": "/api/cron/weekly-digest.js" },
    { "src": "/api/cron/bounce-cleanup", "dest": "/api/cron/bounce-cleanup.js" },
    { "src": "/api/cron/self-improve", "dest": "/api/cron/self-improve.js" },
    { "src": "/api/cron/manager", "dest": "/api/cron/manager.js" },
    { "src": "/api/cron/drip-sender", "dest": "/api/cron/drip-sender.js" }
  ],
  "crons": [
    { "path": "/api/cron/digest", "schedule": "0 7 * * 1-5" },
    { "path": "/api/cron/gmail-poll", "schedule": "*/2 * * * *" },
    { "path": "/api/cron/sender-health", "schedule": "0 6 * * *" },
    { "path": "/api/cron/bounce-cleanup", "schedule": "0 7 * * *" },
    { "path": "/api/cron/manager", "schedule": "0 8 * * *" },
    { "path": "/api/cron/manager", "schedule": "0 14 * * *" },
    { "path": "/api/cron/drip-sender", "schedule": "0 9 * * *" },
    { "path": "/api/cron/prospect-replenish", "schedule": "0 4 * * *" },
    { "path": "/api/cron/weekly-digest", "schedule": "0 6 * * 5" },
    { "path": "/api/cron/self-improve", "schedule": "0 20 * * 0" }
  ]
}
